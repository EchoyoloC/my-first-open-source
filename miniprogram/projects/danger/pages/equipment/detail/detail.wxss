.detail-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.loading-view {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

.content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.status-tag {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 30rpx;
}

.status-tag.expired {
  background-color: #f53f3f;
}

.status-tag.soon-expire {
  background-color: #ff7d00;
}

/* 新增：器材图片样式 */
.img-area {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #eee;
}

.img-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.equipment-img {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  border: 1px solid #f0f0f0;
  object-fit: cover;
}

.info-list {
  border-top: 1px solid #eee;
}

.info-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.empty-view {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  font-size: 28rpx;
  color: #999;
}