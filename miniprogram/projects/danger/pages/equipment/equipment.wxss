/* equipment.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.input, .picker {
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 10rpx;
}

.submit-btn {
  background-color: #07c160;
  color: #fff;
  margin-top: 40rpx;
  border-radius: 10rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* 新增：图片上传区域样式（和现有样式风格统一） */
.upload-area {
  width: 200rpx;
  height: 200rpx;
  border: 1px dashed #ccc;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
}

.upload-btn {
  width: 100%;
  height: 100%;
  background-color: #f9f9f9;
  border: none;
  font-size: 24rpx;
  color: #666;
  padding: 0;
  line-height: normal;
}

.img-preview {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 10rpx;
}

.img-preview image {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.delete-img {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #f56c6c;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
}