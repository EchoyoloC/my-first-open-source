.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.radio-item {
  display: block;
  font-size: 28rpx;
  margin-bottom: 15rpx;
}

.textarea {
  width: 100%;
  height: 200rpx;
  border: 1px solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
}

.img-preview-wrapper {
  position: relative;
  margin-top: 20rpx;
}

.preview-img {
  width: 200rpx;
  height: 200rpx;
  margin-top: 20rpx;
  border-radius: 8rpx;
}

.del-img-btn {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #ff4444;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 15rpx;
  border-radius: 0 8rpx 0 8rpx;
}

.submit-btn {
  background-color: #07c160;
  color: #fff;
  border-radius: 30rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}