<!-- 首页提醒栏 -->
<view class="home-notice" bindtap="goToMessage">
  <view class="notice-icon">
    <image src="../../../images/notice.png" class="icon-img"></image>
    <view class="red-dot" wx:if="{{noticeCount > 0}}">{{noticeCount}}</view>
  </view>
  <view class="notice-text">
    <text wx:if="{{noticeCount > 0}}">有{{noticeCount}}个器材即将过期/已过期</text>
    <text wx:else>暂无器材过期提醒</text>
  </view>
  <image src="../../../images/arrow-right.png" class="arrow-img"></image>
</view>

