@import "../../../style/skin.wxss";

page {
	background-color: #E4E5F7;
}

.main {
	padding: 0;
}

.main .upside {
	height: 400rpx;
	width: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	position: relative;
	overflow: hidden;
}

.main .upside .upImg {
	height: inherit;
	width: 100%;
	position: absolute;
	top: 0;
	left: 0;
}

.pic {
	height: 120rpx;
	width: 120rpx;
	border-radius: 50%;
	background-color: #f8f8f8;
	display: flex;
	align-items: center;
	justify-content: center;
	position: absolute;
	right: 80rpx;
	top: -60rpx;
}

.pic image {
	height: 70rpx;
	width: 70rpx;
}

.info {
	width: 100%;
	padding: 0 20rpx 0 30rpx;
	box-sizing: border-box;
	position: relative;
	background-color: transparent;
	margin-top: -180rpx;
	align-items: flex-end;
}

.info .inner {
	width: 100%;
	height: 120rpx;
	display: flex;
}

.info .inner .left {
	width: 400rpx;
	background-color: #fff;
	border-radius: 50rpx 30rpx 0 0;
	padding: 40rpx 30rpx 10rpx 50rpx;
	z-index: 99;
}

.info .inner .left .line {
	font-size: 32rpx;
	margin-bottom: 10rpx;
	color: var(--projectColor);
	display: flex;
	align-items: baseline;
}

.main .down {
	box-sizing: border-box;
	width: 100%;
	display: flex;
	flex-direction: column;
	justify-content: center;
	padding: 0rpx 0rpx 20rpx 30rpx;
	position: relative;
	margin-top: -40rpx;
}

.menu-list {
	width: 100%;
	display: flex;
	flex-direction: column;
	padding: 0rpx 20rpx 30rpx;
	background-color: #fff;
	border-radius: 0rpx 0rpx 30rpx 50rpx;
}

.menu-list .item {
	width: 100%;
	padding: 22rpx 30rpx;
	border-bottom: 2rpx solid #bbdaff;
	display: flex;
	align-items: center;
}

.menu-list .item:first-child {
	border-top: 4rpx dotted #87b3e9 !important;
} 

.menu-list .item:last-child {
	border: 0;
}

.menu-list .item>image {
	width: 40rpx;
	height: 40rpx;
	margin-right: 20rpx;
}

.menu-list .item .line {
	width: 100%;
	display: flex;
	align-items: center;
	justify-content: space-between;
	font-size: 26rpx;
}

.menu-list .item .line .left {
	flex: 1;
	color: #333;
}

.menu-list .item .line .right {
	color: #666;
}

.todo {
	width: 30rpx;
	height: 30rpx;
	background-color: var(--red);
	font-size: 20rpx;
	color: #fff;
	border-radius: 50%;
	margin-left: 10rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}


.repair {
	background-color: #fff; 
	width: 100%;
	display: flex;
	flex-direction: column;
	justify-content: space-around;
	padding: 100rpx 0rpx 40rpx; 
} 
  

.repair .item-list {
	width: 100%;
	display: flex;
	padding: 0 50rpx;
	justify-content: space-between;
}

.repair .item {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	position: relative; 
}

.repair .item .num {
	padding: 2rpx 8rpx;
	border-radius: 25%;
	background-color: #f76565;
	color: #fff;
	position: absolute;
	top: 0;
	right: 0;
	font-size: 20rpx;
	z-index: 9;
}


.repair .item image {
	width: 50rpx;
	height: 50rpx; 
	margin-bottom: 6rpx;
}

.repair .item text {
	font-size: 24rpx;
}