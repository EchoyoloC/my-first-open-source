<template name="menuTpl"> 
	<view class="tab-bar" >   
		<view wx:if="{{returnHome}}" class="tab-bar-home" bindtap="url" data-type="relaunch"
			data-url="/pages/home/index/home_index">
			<text class="tab-bar-home-text icon-homefill text-grey"></text>
		</view>

		<view class="tab-bar-border"></view> 


		<view class="tab-bar-item" bindtap="url" data-type="relaunch" data-url="/projects/danger/pages/default/index/default_index">
			<image class="tab-icon" src="/projects/danger/images/tabbar/home{{curMenu=='default_index'?'_cur':''}}.png"></image>
			<view class="tab-text {{curMenu=='default_index'?'menu-project':''}}">首页</view>
		</view>   

		<view class="tab-bar-item" bindtap="url" data-type="relaunch" data-url="/projects/danger/pages/news/cate1/news_cate1">
			<image class="tab-icon" src="/projects/danger/images/tabbar/news{{curMenu=='news_cate1'?'_cur':''}}.png"></image>
			<view class="tab-text {{curMenu=='news_cate1'?'menu-project':''}}">通知公告</view>
		</view>   


		<view class="tab-bar-item" bindtap="url" data-type="relaunch" data-url="/projects/danger/pages/task/add/task_add">
			<image class="tab-icon" src="/projects/danger/images/tabbar/add{{curMenu=='task_add'?'_cur':''}}.png"></image>
			<view class="tab-text {{curMenu=='task_add'?'menu-project':''}}">隐患上报</view>
		</view>    

		<view class="tab-bar-item" bindtap="url" data-type="relaunch" data-url="/projects/danger/pages/my/index/my_index">
			<image class="tab-icon" src="/projects/danger/images/tabbar/my{{curMenu=='my_index'?'_cur':''}}.png"></image>
			<view class="tab-text {{curMenu=='my_index'?'menu-project':''}}">我的</view>
		</view>


	</view>
</template>